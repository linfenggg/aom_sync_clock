<chipwatcher project_name="MASTER_FPGA" bit_file="MASTER_FPGA.bit" bid_file="MASTER_FPGA_inst.bid" chip_name="EG4X20BG256">
	<instance name="auto_chipwatcher_0" id="0" enabled="yes">
		<clock clk_name="clk_4m" polarity="posedge"/>
		<config bram_name="auto_chipwatcher_0_logicbram" sample_depth="2048"/>
		<signal_vec>
			<trigger_nets>
				<net name="online1_INT"/>
				<net name="online1_SCL"/>
				<net name="online1_SDA"/>
				<net name="online_1/bit_cnt[0]"/>
				<net name="online_1/bit_cnt[1]"/>
				<net name="online_1/bit_cnt[2]"/>
				<net name="online_1/bit_cnt[3]"/>
				<net name="online_1/data_tem[0]"/>
				<net name="online_1/data_tem[1]"/>
				<net name="online_1/data_tem[2]"/>
				<net name="online_1/data_tem[3]"/>
				<net name="online_1/data_tem[4]"/>
				<net name="online_1/data_tem[5]"/>
				<net name="online_1/data_tem[6]"/>
				<net name="online_1/data_tem[7]"/>
				<net name="online_1/state[0]"/>
				<net name="online_1/state[1]"/>
				<net name="online_1/state[2]"/>
				<net name="online_1/state[3]"/>
				<net name="online_1/state[4]"/>
			</trigger_nets>
			<data_nets>
				<net name="online1_INT"/>
				<net name="online1_SCL"/>
				<net name="online1_SDA"/>
				<net name="online_1/bit_cnt[0]"/>
				<net name="online_1/bit_cnt[1]"/>
				<net name="online_1/bit_cnt[2]"/>
				<net name="online_1/bit_cnt[3]"/>
				<net name="online_1/data_tem[0]"/>
				<net name="online_1/data_tem[1]"/>
				<net name="online_1/data_tem[2]"/>
				<net name="online_1/data_tem[3]"/>
				<net name="online_1/data_tem[4]"/>
				<net name="online_1/data_tem[5]"/>
				<net name="online_1/data_tem[6]"/>
				<net name="online_1/data_tem[7]"/>
				<net name="online_1/state[0]"/>
				<net name="online_1/state[1]"/>
				<net name="online_1/state[2]"/>
				<net name="online_1/state[3]"/>
				<net name="online_1/state[4]"/>
			</data_nets>
			<watcher_nodes>
				<net name="online1_SDA" op="equal"/>
				<net name="online1_SCL" op="equal"/>
				<bus name="online_1/data_tem" radix="bin" state="collapse" op="dont_care">
					<net name="online_1/data_tem[7]"/>
					<net name="online_1/data_tem[6]"/>
					<net name="online_1/data_tem[5]"/>
					<net name="online_1/data_tem[4]"/>
					<net name="online_1/data_tem[3]"/>
					<net name="online_1/data_tem[2]"/>
					<net name="online_1/data_tem[1]"/>
					<net name="online_1/data_tem[0]"/>
				</bus>
				<bus name="online_1/state" radix="undec" state="collapse" op="dont_care">
					<net name="online_1/state[4]"/>
					<net name="online_1/state[3]"/>
					<net name="online_1/state[2]"/>
					<net name="online_1/state[1]"/>
					<net name="online_1/state[0]"/>
				</bus>
				<bus name="online_1/bit_cnt" radix="undec" state="collapse" op="dont_care">
					<net name="online_1/bit_cnt[3]"/>
					<net name="online_1/bit_cnt[2]"/>
					<net name="online_1/bit_cnt[1]"/>
					<net name="online_1/bit_cnt[0]"/>
				</bus>
				<net name="online1_INT" op="equal"/>
			</watcher_nodes>
		</signal_vec>
		<trigger name="auto_chipwatcher_0_trigger" position="pre">
			<condition level="1" enabled="yes" type="basic_and">
				online1_INT == any && online1_SCL == low && online1_SDA == any && online_1/bit_cnt[0] == low && online_1/bit_cnt[1] == low && online_1/bit_cnt[2] == low && online_1/bit_cnt[3] == low && online_1/data_tem[0] == low && online_1/data_tem[1] == low && online_1/data_tem[2] == low && online_1/data_tem[3] == low && online_1/data_tem[4] == low && online_1/data_tem[5] == low && online_1/data_tem[6] == low && online_1/data_tem[7] == low && online_1/state[0] == low && online_1/state[1] == low && online_1/state[2] == low && online_1/state[3] == low && online_1/state[4] == low
			</condition>
			<log>
				<data name="log: 2023/ 4/14 16:42:34" trigger_en="yes" trigger_pos="683" sample_num="2048">
					
				</data>
			</log>
		</trigger>
	</instance>
</chipwatcher>
