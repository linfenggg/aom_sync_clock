<chipwatcher project_name="MASTER_FPGA" bit_file="MASTER_FPGA.bit" bid_file="MASTER_FPGA_inst.bid" chip_name="EG4X20BG256">
	<instance name="auto_chipwatcher_0" id="0" enabled="yes">
		<clock clk_name="clk_50m" polarity="posedge"/>
		<config bram_name="auto_chipwatcher_0_logicbram" sample_depth="1024"/>
		<signal_vec>
			<trigger_nets>
				<net name="core/PUMP_SW1_WR"/>
				<net name="core/PUMP_SW1_tem"/>
				<net name="core/WORK_MODE[0]"/>
				<net name="core/WORK_MODE[1]"/>
				<net name="core/WORK_MODE[2]"/>
				<net name="core/WORK_MODE[3]"/>
				<net name="core/WR"/>
				<net name="error"/>
				<net name="lock"/>
				<net name="start_status"/>
			</trigger_nets>
			<data_nets>
				<net name="core/PUMP_SW1_WR"/>
				<net name="core/PUMP_SW1_tem"/>
				<net name="core/WORK_MODE[0]"/>
				<net name="core/WORK_MODE[1]"/>
				<net name="core/WORK_MODE[2]"/>
				<net name="core/WORK_MODE[3]"/>
				<net name="core/WR"/>
				<net name="error"/>
				<net name="lock"/>
				<net name="start_status"/>
			</data_nets>
			<watcher_nodes>
				<net name="start_status" op="equal"/>
				<net name="error" op="equal"/>
				<net name="lock" op="equal"/>
				<net name="core/PUMP_SW1_WR" op="equal"/>
				<net name="core/WR" op="equal"/>
				<net name="core/PUMP_SW1_tem" op="equal"/>
				<group name="core/WORK_MODE[0]_group" radix="undec" state="collapse" op="dont_care">
					<net name="core/WORK_MODE[0]"/>
					<net name="core/WORK_MODE[1]"/>
					<net name="core/WORK_MODE[2]"/>
					<net name="core/WORK_MODE[3]"/>
				</group>
			</watcher_nodes>
		</signal_vec>
		<trigger name="auto_chipwatcher_0_trigger" position="center">
			<condition level="1" enabled="yes" type="basic_and">
				core/PUMP_SW1_WR == high && core/PUMP_SW1_tem == any && core/WORK_MODE[0] == any && core/WORK_MODE[1] == any && core/WORK_MODE[2] == any && core/WORK_MODE[3] == any && core/WR == any && error == any && lock == any && start_status == any
			</condition>
			<log>
				<data name="log: 2023/ 5/15 15:48:51" trigger_en="yes" trigger_pos="512" sample_num="1024">
					
				</data>
			</log>
		</trigger>
	</instance>
</chipwatcher>
